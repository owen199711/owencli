# LLM Provider
LLM_PROVIDER=anthropic          # anthropic | openai
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Model
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o

# PostgreSQL (Memory Store)
DATABASE_URL=postgresql://user:password@localhost:5432/context_os
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Memory
MEMORY_MAX_TOKENS=128000

# Trace
TRACE_ENABLED=true
TRACE_STORAGE_DIR=./data/traces

# Vector DB (optional)
VECTOR_DB_PROVIDER=pgvector       # pgvector | chroma | qdrant
